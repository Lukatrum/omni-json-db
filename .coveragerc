[run]
branch = True

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError.* 
    raise AttributeError.*
    raise TypeError.*
    raise ValueError.*
    raise KeyError.*
    raise RuntimeError.*
    raise IOError.*
    raise BlockingIOError.*
    raise ModuleNotFoundError.*
    raise JTypeError.*
    raise JValueError.*
    raise JKeyError.*
    except FileNotFoundError.*
    excpet FileLockException.*
    except.*ImportError.*
    except.*ModuleNotFoundError.*
    warnings\.warn.*
    print\(Style\(.*
    def __repr__
    def __str__
    def main()
    def _missing_
    .*GITHUB=NO.*
    def Style
    debug_break
    breakpoint
    if has_SIGINT().*
    if False and .*
    if 0 and .*
    if __name__ == .__main__.:
    return

